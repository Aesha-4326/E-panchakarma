# Example environment variables for local or production
MYSQL_HOST=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=example_root_password
MYSQL_DATABASE=e_panchakarma
MYSQL_PORT=3306

# SMTP (email) settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=E-Panchakarma
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_AUDIENCE_STRICT=false

# App settings
APP_DEBUG=false

# Notes: copy this file to .env.local and fill real secrets for local runs.
